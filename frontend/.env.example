# Copy this file to .env and fill in values. Do not commit .env.


# Cluster: devnet | testnet | mainnet-beta | localnet
# localnet = http://127.0.0.1:8899 (run: solana-test-validator)
# VITE_SOLANA_CLUSTER=devnet
# Optional override for any cluster (Solana JSON-RPC):
# VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# Legacy name; must be a Solana RPC.
# VITE_RPC_URL=

